{
  "manifest_version": 3,
  "name": "Universal Captions",
  "version": "0.1.0",
  "description": "Live captioning overlay for any tab.",

  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Universal Captions"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/caption-overlay.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["pip/pip-window.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
